# Database (local SQLite - no setup needed)
DATABASE_URL="file:./prisma/dev.db"

# === REQUIRED ===

# Anthropic (Claude API - Hebrew captions, hashtags, AI features)
# Get key at: console.anthropic.com
ANTHROPIC_API_KEY="your_anthropic_api_key"

# fal.ai (Photo enhancement via Nano Banana)
# Get key at: fal.ai
FAL_KEY="your_fal_key"

# === FOR ANALYTICS (read-only, set up together at meeting) ===

# Shopify (pulls sales data, customers, products)
SHOPIFY_STORE_URL="your-store.myshopify.com"
SHOPIFY_ACCESS_TOKEN="shpat_xxxxx"

# Meta (pulls Instagram + Facebook analytics - NOT used for posting)
# Posting is done through Meta Business Suite (free, business.facebook.com)
META_ACCESS_TOKEN="your_meta_access_token"
META_PAGE_ID="your_page_id"
META_IG_USER_ID="your_ig_user_id"

# Pinterest (pulls pin analytics - NOT used for posting)
# Posting is done through Pinterest Business (free, business.pinterest.com)
PINTEREST_ACCESS_TOKEN="your_pinterest_access_token"
PINTEREST_BOARD_ID="your_board_id"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3007"
